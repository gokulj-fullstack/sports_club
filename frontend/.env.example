# Base API URL (already includes /api) — used by every page that talks to the backend.
REACT_APP_API_URL=http://localhost:8000/api

# Where the separate admin dashboard app is hosted. Used only to redirect
# staff/admin accounts after login — see src/components/auth/Login.js.
# Dev default matches the admin app's Vite dev server (npm run dev in admin/).
REACT_APP_ADMIN_URL=http://localhost:5173
